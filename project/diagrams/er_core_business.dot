digraph ERCoreBusiness {
  graph [rankdir=LR, splines=ortho, nodesep=0.55, ranksep=0.95, fontname="Microsoft YaHei", labelloc=t, label="核心业务 E-R 图"];
  node [shape=record, style="rounded,filled", fillcolor="#F8FBFF", color="#2B6CB0", fontname="Microsoft YaHei", fontsize=10];
  edge [color="#4A5568", arrowsize=0.7, fontname="Microsoft YaHei", fontsize=9];

  subgraph cluster_visitor {
    label="访客域"; color="#BBD7FF"; style="rounded";
    visitor [label="{visitor|id PK\lvisitor_name\lphone\lid_number\lcompany\lstatus\l}"];
    visitor_vehicle [label="{visitor_vehicle|id PK\lvisitor_id FK\lplate_no\lvehicle_type\lstatus\l}"];
    blacklist [label="{blacklist|id PK\lvisitor_id FK\lphone\lreason\llevel\lstatus\l}"];
  }

  subgraph cluster_apply {
    label="预约审批域"; color="#BDECCB"; style="rounded";
    visit_apply [label="{visit_apply|id PK\lapply_no\lvisitor_id FK\lhost_user_id FK\ldepartment_id FK\lapply_status\laccess_status\l}"];
    visitor_companion [label="{visitor_companion|id PK\lapply_id FK\lcompanion_name\lid_number\lphone\l}"];
    approval_record [label="{approval_record|id PK\lapply_id FK\lapproval_step\lapprover_user_id FK\lapproval_result\lapproval_time\l}"];
  }

  subgraph cluster_access {
    label="通行核验域"; color="#FFE4B5"; style="rounded";
    pass_code [label="{pass_code|id PK\lapply_id FK\lpass_code\lvalid_from\lvalid_to\lpass_status\l}"];
    access_record [label="{access_record|id PK\lapply_id FK\lpass_code_id FK\lentry_gate_id FK\lexit_gate_id FK\laccess_status\l}"];
    campus_gate [label="{campus_gate|id PK\lgate_code\lgate_name\lgate_type\lstatus\l}"];
  }

  { rank=same; visitor; visitor_vehicle; blacklist; }
  { rank=same; visit_apply; visitor_companion; approval_record; }
  { rank=same; pass_code; access_record; campus_gate; }

  visitor -> visit_apply [label="1:N submits"];
  visitor -> visitor_vehicle [label="1:N owns"];
  visitor_vehicle -> visit_apply [label="1:N selected"];
  visit_apply -> visitor_companion [label="1:N includes"];
  visit_apply -> approval_record [label="1:N approval"];
  visit_apply -> pass_code [label="1:0..1 issue"];
  pass_code -> access_record [label="1:N verify"];
  visit_apply -> access_record [label="1:N archive"];
  campus_gate -> access_record [label="1:N gate"];
  visitor -> blacklist [label="1:N risk"];
}